%==========================%
%      MATH SHORTCUTS      %
%==========================%
\newcommand{\R}{\mathbb{R}}     % Real numbers
\newcommand{\Z}{\mathbb{Z}}     % Integers
\newcommand{\N}{\mathbb{N}}     % Natural numbers
\newcommand{\C}{\mathbb{C}}     % Complex numbers
\newcommand{\Q}{\mathbb{Q}}     % Rational numbers

\newcommand{\pfrac}[2]{\left( \frac{#1}{#2} \right)}   % Parenthesized fraction
\newcommand{\sqfrac}[2]{\left[ \frac{#1}{#2} \right]}  % Square bracket fraction
\newcommand{\bfrac}[2]{\frac{\sqbrac{#1}}{\sqbrac{#2}}} 

\newcommand{\paren}[1]{\left( #1 \right)}
\newcommand{\sqbrac}[1]{\left[ #1 \right]}
\newcommand{\sqbracc}[1]{\left[ \phantom{\frac{}{}} #1 \phantom{\frac{}{}} \right]}
\newcommand{\set}[1]{\left\{ #1 \right\}}
\newcommand{\myset}[2]{\left\{ {#1}_1, {#1}_2, \dots, {#1}_{#2} \right\}}

\newcommand{\modu}[1]{\left| #1 \right|}
\newcommand{\norm}[1]{\modu{\modu{#1}}}
\newcommand{\intf}[1]{\int_{-\infty}^{\infty} #1 \, dx}

\newcommand{\dd}{\partial}
\newcommand{\ti}{\times}
\newcommand{\seq}{\subseteq}
\newcommand{\var}{\varepsilon}
\newcommand{\mn}{\mathcal{F}}

\newcommand{\Qed}{\tag*{$\square$}}  % QED box at end of line
\newcommand{\sq}{\square}
\newcommand{\heart}{\textcolor{red}{\ding{170}}}
\newcommand{\cutei}{\mathop{{}\imath}\limits^{\scriptscriptstyle\heartsuit}}

\newcommand{\bigO}[1]{\mathcal{O}\paren{#1}}  % Big O notation

%==========================%
%      LOGIC SHORTCUTS     %
%==========================%
\newcommand{\imp}{\rightarrow}
\newcommand{\ifff}{\leftrightarrow}
\newcommand{\nott}{\neg}
\newcommand{\orr}{\vee}
\newcommand{\andd}{\wedge}
\newcommand{\poss}{\lozenge}
\newcommand{\tf}{\therefore}
\newcommand{\bs}{\backslash}
\newcommand{\al}{\alpha}
\newcommand{\be}{\beta}
\newcommand{\half}{\frac{1}{2}}
\newcommand{\m}[1]{\mathbf{#1}}
\newcommand{\grad}{\nabla}
\newcommand{\gradx}[2]{\frac{\dd#1}{\dd x_{#2}}}
\newcommand{\ms}[1]{\boldsymbol{#1}}
\newcommand{\todo}[1]{{\huge\textcolor{red}{#1}}}
